---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About dasomel">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16">
    <header class="mb-16">
      <div class="mb-8">
        <img
          src="/images/dasomel.jpg"
          alt="dasomel"
          class="w-28 h-28 rounded-full object-cover ring-2 ring-gray-100"
        />
      </div>
      <p class="font-mono text-xs text-gray-400 mb-3">$ cat profile.json<span class="cursor-blink inline-block ml-0.5 text-emerald-500">▋</span></p>
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-3 leading-tight tracking-tight">
        Cloud & DevOps <span class="text-emerald-600">Engineer</span>
      </h1>
      <p class="text-gray-500">
        Building open source projects and leading developer communities
      </p>
    </header>

    <div class="space-y-12">
      <!-- Career -->
      <section>
        <div class="flex items-center gap-4 mb-6">
          <h2 class="font-mono text-xs text-gray-400 whitespace-nowrap">01 — Career</h2>
          <div class="flex-1 border-t border-dashed border-gray-200"></div>
        </div>
        <div class="space-y-0 border-l border-gray-100 ml-1">
          <div class="pl-6 pb-8 relative">
            <div class="absolute -left-1.5 top-1.5 w-3 h-3 rounded-full bg-white border-2 border-gray-300"></div>
            <div class="p-5 bg-white border border-gray-100 rounded-xl hover:border-gray-200 hover:border-l-emerald-500 transition-all">
              <div class="flex items-start justify-between mb-3">
                <h3 class="font-bold text-gray-900">Tech University of Korea</h3>
                <span class="font-mono text-xs text-gray-400 whitespace-nowrap ml-4">Mar 2026 ~</span>
              </div>
              <ul class="text-gray-600 text-sm space-y-1.5">
                <li>Adjunct Professor, IT Management (SW Framework)</li>
              </ul>
            </div>
          </div>
          <div class="pl-6 pb-8 relative">
            <div class="absolute -left-1.5 top-1.5 w-3 h-3 rounded-full bg-white border-2 border-gray-300"></div>
            <div class="p-5 bg-white border border-gray-100 rounded-xl hover:border-gray-200 hover:border-l-emerald-500 transition-all">
              <div class="flex items-start justify-between mb-3">
                <h3 class="font-bold text-gray-900">2nd SI Company</h3>
                <span class="font-mono text-xs text-gray-400 whitespace-nowrap ml-4">2021 ~ 2025</span>
              </div>
              <ul class="text-gray-600 text-sm space-y-1.5">
                <li>Data Platform Development (2022 ~ 2025)</li>
                <li>AI Platform Operations (2022)</li>
                <li>Kubernetes Platform Development Lead (2021)</li>
              </ul>
            </div>
          </div>
          <div class="pl-6 pb-2 relative">
            <div class="absolute -left-1.5 top-1.5 w-3 h-3 rounded-full bg-white border-2 border-gray-300"></div>
            <div class="p-5 bg-white border border-gray-100 rounded-xl hover:border-gray-200 hover:border-l-emerald-500 transition-all">
              <div class="flex items-start justify-between mb-3">
                <h3 class="font-bold text-gray-900">1st SI Company</h3>
                <span class="font-mono text-xs text-gray-400 whitespace-nowrap ml-4">2012 ~ 2021</span>
              </div>
              <ul class="text-gray-600 text-sm space-y-1.5">
                <li>Cloud Projects (2017 ~ 2020)</li>
                <li>Internal Training Instructor</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- Awards -->
      <section>
        <div class="flex items-center gap-4 mb-6">
          <h2 class="font-mono text-xs text-gray-400 whitespace-nowrap">02 — Awards</h2>
          <div class="flex-1 border-t border-dashed border-gray-200"></div>
        </div>
        <div class="grid sm:grid-cols-2 gap-3">
          <div class="p-4 bg-white border border-gray-100 rounded-xl">
            <p class="font-bold text-gray-900 text-sm">OPA Awards - Community Hero</p>
            <p class="font-mono text-xs text-gray-400 mt-1">2025</p>
          </div>
          <div class="p-4 bg-white border border-gray-100 rounded-xl">
            <p class="font-bold text-gray-900 text-sm">OPA Awards - Outstanding Contributor</p>
            <p class="font-mono text-xs text-gray-400 mt-1">2024</p>
          </div>
          <div class="p-4 bg-white border border-gray-100 rounded-xl">
            <p class="font-bold text-gray-900 text-sm">Minister of Public Administration Award</p>
            <p class="font-mono text-xs text-gray-400 mt-1">2021</p>
          </div>
          <div class="p-4 bg-white border border-gray-100 rounded-xl">
            <p class="font-bold text-gray-900 text-sm">Super Developer K Season 3 - Bronze</p>
            <p class="font-mono text-xs text-gray-400 mt-1">2014</p>
          </div>
        </div>
      </section>

      <!-- Community -->
      <section>
        <div class="flex items-center gap-4 mb-6">
          <h2 class="font-mono text-xs text-gray-400 whitespace-nowrap">03 — Community</h2>
          <div class="flex-1 border-t border-dashed border-gray-200"></div>
        </div>
        <div class="space-y-3">
          <a href="https://opdc.kr" target="_blank" rel="noopener noreferrer"
             class="block p-5 bg-white border border-gray-100 rounded-xl hover:border-gray-200 hover:border-l-emerald-500 hover:shadow-sm transition-all group">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-bold text-gray-900 group-hover:text-emerald-600 transition-colors">OPDC</h3>
              <span class="px-2.5 py-1 bg-emerald-100 text-emerald-700 rounded-full text-xs font-medium">Leader</span>
            </div>
            <p class="text-gray-500 text-sm">Open Platform Developer Community</p>
          </a>

          <a href="https://opakorea.org" target="_blank" rel="noopener noreferrer"
             class="block p-5 bg-white border border-gray-100 rounded-xl hover:border-gray-200 hover:border-l-emerald-500 hover:shadow-sm transition-all group">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-bold text-gray-900 group-hover:text-emerald-600 transition-colors">OPA</h3>
              <span class="px-2.5 py-1 bg-emerald-100 text-emerald-700 rounded-full text-xs font-medium">Leader</span>
            </div>
            <p class="text-gray-500 text-sm">Open cloud Platform Alliance</p>
          </a>

          <a href="https://www.cloudbro.ai" target="_blank" rel="noopener noreferrer"
             class="block p-5 bg-white border border-gray-100 rounded-xl hover:border-gray-200 hover:border-l-emerald-500 hover:shadow-sm transition-all group">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-bold text-gray-900 group-hover:text-emerald-600 transition-colors">CloudBro</h3>
              <span class="px-2.5 py-1 bg-gray-100 text-gray-600 rounded-full text-xs font-medium">Member</span>
            </div>
            <p class="text-gray-500 text-sm">Cloud Technology Community</p>
          </a>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
